{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/booking/:doctorId", "destination": "/booking/[doctorId].html" },
    { "source": "/doctor/:id", "destination": "/doctor/[id].html" },
    { "source": "/telemedicine/:appointmentId", "destination": "/telemedicine/[appointmentId].html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/_expo/static/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
