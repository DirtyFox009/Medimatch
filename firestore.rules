rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function authed() { return request.auth != null; }
    function isOwner(uid) { return authed() && request.auth.uid == uid; }

    // ── User profiles ────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid);
      // Self-signup may only create a patient profile; doctor accounts are
      // provisioned by the admin script (scripts/provisionDoctorAccounts.ts).
      allow create: if isOwner(uid)
        && request.resource.data.role == 'patient'
        && request.resource.data.uid == uid;
      // Role and doctor linkage can never be self-modified.
      allow update: if isOwner(uid)
        && request.resource.data.get('role', 'patient') == resource.data.get('role', 'patient')
        && request.resource.data.get('doctorId', null) == resource.data.get('doctorId', null);
      allow delete: if false;

      match /records/{recordId} {
        allow read, write: if isOwner(uid);
      }
      match /medicines/{medicineId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Doctors (seeded via admin SDK) ───────────────────────────────────
    match /doctors/{doctorId} {
      allow read: if authed();
      // A doctor may edit their own profile's practice details. Identity and
      // trust fields (name, specialty, bmdcReg, isVerified, ratings) remain
      // operator-only via the seed/provision scripts.
      allow update: if authed()
        && resource.data.get('userId', '') == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['isAvailable', 'qualifications', 'hospitalNameEn',
                       'hospitalNameBn', 'consultationFee', 'telemedicineFee',
                       'telemedicineAvailable', 'availableDays', 'timeSlots',
                       'bio', 'updatedAt'])
        && request.resource.data.consultationFee is number
        && request.resource.data.consultationFee >= 0
        && request.resource.data.telemedicineFee is number
        && request.resource.data.telemedicineFee >= 0;
      // Rating aggregation: any authed user may advance the rating fields by
      // exactly one review. Runs in the same transaction as the review create
      // below, whose rule enforces the completed-appointment requirement.
      allow update: if authed()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['ratingAvg', 'reviewCount', 'updatedAt'])
        && request.resource.data.reviewCount == resource.data.reviewCount + 1
        && request.resource.data.ratingAvg >= 0
        && request.resource.data.ratingAvg <= 5;
      allow create, delete: if false;

      // Public booking ledger — opaque slot occupancy, no health data.
      match /slots/{slotId} {
        allow read: if authed();
        allow create: if authed()
          && request.resource.data.bookedBy == request.auth.uid
          && request.resource.data.keys().hasAll(['date', 'timeSlot', 'bookedBy', 'appointmentId']);
        // Freed on cancellation by the patient who booked it, or by the
        // doctor who owns this doctor profile.
        allow delete: if authed()
          && (resource.data.bookedBy == request.auth.uid
              || get(/databases/$(database)/documents/doctors/$(doctorId)).data.get('userId', '') == request.auth.uid);
        allow update: if false;
      }

      // Review id == appointmentId → exactly one review per appointment,
      // and only for a completed appointment with this doctor.
      match /reviews/{appointmentId} {
        allow read: if authed();
        allow create: if authed()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
          && request.resource.data.comment is string
          && request.resource.data.comment.size() <= 1000
          && get(/databases/$(database)/documents/appointments/$(appointmentId)).data.patientId == request.auth.uid
          && get(/databases/$(database)/documents/appointments/$(appointmentId)).data.doctorId == doctorId
          && get(/databases/$(database)/documents/appointments/$(appointmentId)).data.status == 'completed';
        allow update, delete: if false;
      }
    }

    // ── Appointments ─────────────────────────────────────────────────────
    match /appointments/{appointmentId} {
      allow read: if authed()
        && (resource.data.patientId == request.auth.uid
            || resource.data.get('doctorUserId', '') == request.auth.uid);
      allow create: if authed()
        && request.resource.data.patientId == request.auth.uid
        && request.resource.data.status in ['pending', 'confirmed']
        && request.resource.data.keys().hasAll(
             ['patientId', 'doctorId', 'date', 'timeSlot', 'type', 'fee', 'status'])
        && request.resource.data.type in ['in-person', 'telemedicine'];
      // Patient may only cancel; doctor may confirm/complete/cancel.
      allow update: if authed()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'updatedAt', 'notes'])
        && (
          (resource.data.patientId == request.auth.uid
             && request.resource.data.status == 'cancelled')
          || (resource.data.get('doctorUserId', '') == request.auth.uid
             && request.resource.data.status in ['confirmed', 'completed', 'cancelled'])
        );
      allow delete: if false;
    }

    // ── Prescriptions ────────────────────────────────────────────────────
    // Doc id == appointmentId → exactly one prescription per appointment.
    // Immutable once written: a prescription is a medical document of record.
    match /prescriptions/{appointmentId} {
      allow read: if authed()
        && (resource.data.patientId == request.auth.uid
            || resource.data.doctorUserId == request.auth.uid);
      // Only the doctor who owns the appointment may issue its prescription,
      // and the patientId must match the appointment's real patient.
      allow create: if authed()
        && request.resource.data.doctorUserId == request.auth.uid
        && get(/databases/$(database)/documents/doctors/$(request.resource.data.doctorId)).data.get('userId', '') == request.auth.uid
        && get(/databases/$(database)/documents/appointments/$(appointmentId)).data.get('doctorUserId', '') == request.auth.uid
        && request.resource.data.patientId
             == get(/databases/$(database)/documents/appointments/$(appointmentId)).data.patientId
        && request.resource.data.appointmentId == appointmentId
        && request.resource.data.keys().hasAll(
             ['appointmentId', 'patientId', 'doctorId', 'doctorUserId',
              'patientName', 'diagnosis', 'items', 'date'])
        && request.resource.data.items is list
        && request.resource.data.items.size() >= 1
        && request.resource.data.items.size() <= 20
        && request.resource.data.patientName is string
        && request.resource.data.patientName.size() > 0
        && request.resource.data.patientName.size() <= 200
        && request.resource.data.diagnosis is string
        && request.resource.data.diagnosis.size() <= 2000;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
