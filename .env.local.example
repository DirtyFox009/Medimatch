# Copy this file to .env.local and fill in your values

# Firebase — from Firebase Console → Project Settings → Your apps → Web app config
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Seed script only — download from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Groq AI symptom triage is proxied through a Vercel serverless function so the
# API key is never bundled into the client. The key itself is set as GROQ_API_KEY
# in the Vercel project dashboard — NOT here. Only override the proxy URL if your
# Vercel deployment uses a different domain:
# EXPO_PUBLIC_GROQ_PROXY_URL=https://your-project.vercel.app/api/groq
